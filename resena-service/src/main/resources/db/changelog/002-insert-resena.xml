        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="2" author="resena-service">

        <insert tableName="resena">
            <column name="cliente_id" valueNumeric="1"/>
