<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="1-create-pago" author="dev">

        <createTable tableName="pago">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_PAGO"
                             nullable="false"/>
            </column>

       
            <column name="id_compra" type="BIGINT"/>

            <column name="monto" type="DOUBLE">
                <constraints nullable="false"/>
            </column>

            <column name="metodo_pago" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="estado" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="fecha_pago" type="DATE"/>

        </createTable>

    </changeSet>

</databaseChangeLog>